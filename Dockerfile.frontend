# 前端 Dockerfile - Vue 3 + Vite 现代化技术栈
FROM node:20-slim AS builder

WORKDIR /app

# 复制新项目的 package.json
COPY recruit-system/recruit-web-vite/package.json ./
RUN npm install --registry=https://registry.npmmirror.com

# 复制项目文件
COPY recruit-system/recruit-web-vite/ ./

# 构建
RUN npm run build

FROM nginx:alpine

COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
